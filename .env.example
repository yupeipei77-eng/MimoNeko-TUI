# MimoNeko Environment Variables Configuration
# Copy this file to .env and fill in your values

# API Keys for Model Providers
# MIMO API Key (for Xiaomi Mimo models)
MIMO_API_KEY=your-mimo-api-key-here

# OpenAI API Key (if using OpenAI-compatible providers)
OPENAI_API_KEY=your-openai-api-key-here

# Other provider API keys (add as needed)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
GLM_API_KEY=your-glm-api-key-here

# Optional: Custom configuration paths
# MimoNeko_CONFIG_DIR=./.mimoneko
# MimoNeko_WORKTREE_ROOT=./.mimoneko/worktrees

# Optional: Debug and logging
# MimoNeko_DEBUG=true
# MimoNeko_LOG_LEVEL=info

# Optional: Server configuration
# MimoNeko_SERVER_PORT=8765
# MimoNeko_SERVER_HOST=127.0.0.1
